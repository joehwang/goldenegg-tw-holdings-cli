## 📦 `pyproject.toml`

```toml
[tool.poetry]
name = "goldenegg-mcp"
version = "0.1.0"
description = "提供持股資訊查詢與記憶的 MCP Plugin"
authors = ["Your Name <you@example.com>"]
readme = "README.md"
packages = [{ include = "goldenegg" }, { include = "mcp_plugin" }]

[tool.mcp.plugin]
name = "goldenegg"
version = "0.1.0"
description = "提供持股查詢與儲存的 MCP 插件"
entrypoint = "mcp_plugin.goldenegg_plugin"
commands = ["save_holdings", "get_holdings"]

[tool.poetry.dependencies]
python = "^3.10"
mcp-server = "^0.2.0"
pydantic = "^2.0"
httpx = "^0.27.0"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"


