**pyproject.toml 設定**：
```toml
[project]
name = "golden-egg"
version = "0.1.0"
requires-python = ">=3.13"
dependencies = [
    "fastmcp>=2.9.2",
    "pydantic-settings>=2.10.1",
    "esun-trade",
    "fubon-neo", 
    "masterlink-sdk",
    "shioaji>=1.2.6",
    # ... 其他依賴
]

[tool.mcp.plugin]
name = "goldenegg"
version = "0.1.0"
description = "提供持股查詢與儲存的 MCP 插件"
entrypoint = "service.mcp_server"  # 更新為新的入口點
tools = ["save_holdings", "get_holdings"]
resources = ["broker_configs", "ocr_history", "holdings_schema"]
prompts = ["save_ocr_data", "query_holdings", "broker_integration"]
```

